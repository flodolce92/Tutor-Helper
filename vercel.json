{
  "buildCommand": "npm run build",
  "devCommand": "vite --port $PORT",
  "functions": {
    "api/**/*.js": {
      "runtime": "@vercel/node@5.6.10"
    }
  },
  "rewrites": [
    {
      "source": "/api/v2/(.*)",
      "destination": "/api/v2/[...path]"
    },
    {
      "source": "/((?!api/|@|src/|node_modules/|favicon/|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
